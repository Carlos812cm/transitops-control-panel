{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/name-role-value": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "scrollbar-color",
          "scrollbar-gutter",
          "scrollbar-gutter",
          "scrollbar-color"
        ]
      }
    ]
  },
  "browserslist": [
    "defaults",
    "not ie 11",
    "not ios_saf <= 18.5",
    "not safari <= 18.5"
  ]
}