{
  "name": "transitops-control-panel",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --open --port 4200",
    "api": "node server/mock/index.cjs",
    "api:dev": "node --watch server/mock/index.cjs",
    "api:real": "cd server && npm run dev",
    "api:real:seed": "cd server && npm run seed",
    "api:real:typecheck": "cd server && npm run typecheck",
    "api:real:test": "cd server && npm run test",
    "api:real:build": "cd server && npm run build",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:api": "vitest run server/mock/index.test.mjs --environment node",
    "serve:ssr:transitops-control-panel": "node dist/transitops-control-panel/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.12",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
