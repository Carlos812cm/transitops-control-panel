# TransitOps API environment example
# Copy this file as server/.env for local development.
# Never commit real secrets.

NODE_ENV=development
PORT=4000
API_PREFIX=/api

# Front-End origin allowed by CORS.
# Local Angular:
CLIENT_URL=http://localhost:4200

# PostgreSQL connection string.
# Local Docker example:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transitops_platform_db

# JWT configuration.
# Use a long random value in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# Optional path for persisted uploaded files.
# Defaults to server/uploads.
UPLOADS_DIR=